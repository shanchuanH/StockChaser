{
  "_comment": "StockChaser 个人化操作手册配置 - 改这里就改全局策略",
  "portfolio_cash_usd": 10000,
  "max_positions": 5,
  "cash_buffer_pct": 25,
  "risk_per_trade_pct": 1.5,
  "max_position_size_pct": 20,
  "entry_style": "3_batch",
  "entry_batches": [
    {"step": 1, "weight_pct": 7,  "trigger": "立即买入 (PRIORITY 信号)"},
    {"step": 2, "weight_pct": 7,  "trigger": "涨 +3% 且未跌破 SMA10"},
    {"step": 3, "weight_pct": 6,  "trigger": "突破 4W 高"}
  ],
  "stop_ladder": [
    {"after_gain_pct": 0,  "stop_logic": "initial_atr",   "desc": "入场价 - 1.5 ATR"},
    {"after_gain_pct": 5,  "stop_logic": "breakeven",     "desc": "保本 (入场价)"},
    {"after_gain_pct": 10, "stop_logic": "entry_plus_5",  "desc": "入场价 + 5%"},
    {"after_gain_pct": 20, "stop_logic": "trail_sma20",   "desc": "动态跟踪 SMA20"}
  ],
  "profit_taking": [
    {"r_multiple": 1, "reduce_fraction": 0.25, "desc": "回本+一倍风险, 减 1/4"},
    {"r_multiple": 2, "reduce_fraction": 0.33, "desc": "锁大部利润, 减 1/3"},
    {"r_multiple": 3, "reduce_fraction": 0.00, "desc": "骑趋势, 剩余用 SMA20 追踪"}
  ],
  "exit_triggers": [
    "触发硬止损 → 全部清仓",
    "Conviction 跌破 45 → 减半仓",
    "SPY 跌破 SMA50 (Regime 转向) → 减半仓",
    "时间止损: 持仓 4 周仍未到 +1R → 减半仓",
    "单日跌幅 > 8% (黑天鹅) → 减至 30%"
  ]
}
